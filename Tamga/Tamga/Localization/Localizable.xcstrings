    "about.description": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga هو محرر نصوص أصلي لنظام macOS مع تمييز بناء الجملة ودعم علامات التبويب."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga হল সিনট্যাক্স হাইলাইটিং এবং ট্যাব সমর্থন সহ একটি নেটিভ macOS টেক্সট এডিটর।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga ist ein nativer macOS-Texteditor mit Syntaxhervorhebung und Tab-Unterstützung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga is a native macOS text editor with syntax highlighting and tab support."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga es un editor de texto nativo para macOS con resaltado de sintaxis y soporte de pestañas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga est un éditeur de texte natif pour macOS avec coloration syntaxique et support des onglets."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga एक नेटिव macOS टेक्स्ट एडिटर है जो सिंटैक्स हाइलाइटिंग और टैब समर्थन के साथ आता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga adalah editor teks macOS dengan penyorotan sintaks dan dukungan tab."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga è un editor di testo nativo per macOS con evidenziazione della sintassi e supporto per schede."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamgaはシンタックスハイライトとタブ機能を備えたネイティブmacOSテキストエディタです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga는 구문 강조 및 탭 지원 기능을 갖춘 네이티브 macOS 텍스트 편집기입니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga is een native macOS teksteditor met syntax highlighting en tabondersteuning."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga to natywny edytor tekstu macOS z podświetlaniem składni i obsługą kart."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga é um editor de texto nativo para macOS com realce de sintaxe e suporte a abas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga — это нативный текстовый редактор для macOS с подсветкой синтаксиса и поддержкой вкладок."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga เป็นโปรแกรมแก้ไขข้อความ macOS ที่มีการเน้นไวยากรณ์และรองรับแท็บ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga, söz dizimi renklendirme ve sekme desteği olan yerel bir macOS metin düzenleyicisidir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga — це нативний текстовий редактор для macOS з підсвічуванням синтаксису та підтримкою вкладок."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga là trình soạn thảo văn bản macOS với tô sáng cú pháp và hỗ trợ tab."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamga 是一款原生 macOS 文本编辑器，支持语法高亮和标签页功能。"
          }
        }
      }
    },
