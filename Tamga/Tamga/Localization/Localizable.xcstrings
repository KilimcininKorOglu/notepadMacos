    "install.cli.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم تثبيت أمر 'tamga' في /usr/local/bin. يمكنك بعد ذلك فتح الملفات من الطرفية باستخدام 'tamga filename.txt'."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এটি /usr/local/bin-এ 'tamga' কমান্ড ইনস্টল করবে। তারপর আপনি 'tamga filename.txt' ব্যবহার করে টার্মিনাল থেকে ফাইল খুলতে পারবেন।"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies installiert den Befehl 'tamga' in /usr/local/bin. Sie können dann Dateien vom Terminal aus mit 'tamga filename.txt' öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will install the 'tamga' command to /usr/local/bin. You can then open files from the terminal using 'tamga filename.txt'."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto instalará el comando 'tamga' en /usr/local/bin. Luego podrás abrir archivos desde la terminal usando 'tamga filename.txt'."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci installera la commande 'tamga' dans /usr/local/bin. Vous pourrez ensuite ouvrir des fichiers depuis le terminal avec 'tamga filename.txt'."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह /usr/local/bin में 'tamga' कमांड इंस्टॉल करेगा। फिर आप 'tamga filename.txt' का उपयोग करके टर्मिनल से फ़ाइलें खोल सकते हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan memasang perintah 'tamga' ke /usr/local/bin. Anda kemudian dapat membuka file dari terminal menggunakan 'tamga filename.txt'."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo installerà il comando 'tamga' in /usr/local/bin. Potrai poi aprire file dal terminale usando 'tamga filename.txt'."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、'tamga'コマンドが/usr/local/binにインストールされます。その後、'tamga filename.txt'を使用してターミナルからファイルを開くことができます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'tamga' 명령어가 /usr/local/bin에 설치됩니다. 그런 다음 'tamga filename.txt'를 사용하여 터미널에서 파일을 열 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit installeert het 'tamga'-commando in /usr/local/bin. Je kunt dan bestanden openen vanuit de terminal met 'tamga filename.txt'."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To zainstaluje polecenie 'tamga' w /usr/local/bin. Następnie możesz otwierać pliki z terminala używając 'tamga filename.txt'."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso instalará o comando 'tamga' em /usr/local/bin. Você poderá então abrir arquivos do terminal usando 'tamga filename.txt'."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это установит команду 'tamga' в /usr/local/bin. Затем вы сможете открывать файлы из терминала с помощью 'tamga filename.txt'."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "นี่จะติดตั้งคำสั่ง 'tamga' ไปที่ /usr/local/bin คุณสามารถเปิดไฟล์จากเทอร์มินัลโดยใช้ 'tamga filename.txt'"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, 'tamga' komutunu /usr/local/bin dizinine kuracaktır. Ardından terminalden 'tamga dosya.txt' yazarak dosya açabilirsiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це встановить команду 'tamga' до /usr/local/bin. Потім ви зможете відкривати файли з терміналу за допомогою 'tamga filename.txt'."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Điều này sẽ cài đặt lệnh 'tamga' vào /usr/local/bin. Sau đó bạn có thể mở tệp từ terminal bằng 'tamga filename.txt'."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将在 /usr/local/bin 中安装 'tamga' 命令。然后您可以使用 'tamga filename.txt' 从终端打开文件。"
          }
        }
      }
    },
